global_defs {
    router_id lb-{{ inventory_hostname }}
}

vrrp_script chk_haproxy {
    script "/usr/bin/killall -0 haproxy"
    interval 2
    weight 10
    fall 3
    rise 2
}

vrrp_instance VI_1 {
    state BACKUP
    interface eth0
    virtual_router_id 90
    priority {{ 200 - groups['kube_control_plane'].index(inventory_hostname) * 10 }}
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass HampsterFragment
    }
    virtual_ipaddress {
        {{ control_plane_virtual_ip }}
    }
    track_script {
        chk_haproxy
    }
}