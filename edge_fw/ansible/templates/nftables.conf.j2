#!/usr/sbin/nft -f

flush ruleset

table ip nat {
    chain prerouting {
        type nat hook prerouting priority -100;

        {% for mapping in nft_dnat_mappings %}
        iifname "eth0" tcp dport {{ mapping.src_port }} dnat to {{ mapping.dest_ip }}:{{ mapping.dest_port }}
        {% endfor %}
    }
}

table inet filter {
  chain forward {
    type filter hook forward priority 0;
    policy drop;

    ct state { established, related } accept

    iifname "eth0" oifname "eth0" tcp ct state new ct original ip daddr {{ ansible_host }} accept
  }
}